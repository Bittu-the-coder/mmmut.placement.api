  "placement_procedure": [
    { "step": 1, "title": "Mailing", "description": "Interested Recruiters mail the JD at tnp@mmmut.ac.in including CTC, Job Roles, Eligibility Criteria and other relevant details." },
    { "step": 2, "title": "Register", "description": "T&P Cell shares it among eligible and interested candidates through Superset Platform / Notice & G-Form." },
    { "step": 3, "title": "Share", "description": "Within a few working days, T&P shares the excel containing list of interested & eligible candidates to the recruiter." },
    { "step": 4, "title": "Date", "description": "Recruiter informs about dates required for process and T&P coordinates accordingly till successful completion." },
    { "step": 5, "title": "Offer", "description": "The company rolls out the offer letter either to T&P or to the candidates, and T&P coordinates accordingly." }
  ]
